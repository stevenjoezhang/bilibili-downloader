  "bugs": {
    "url": "https://github.com/stevenjoezhang/bilibili-downloader/issues"
  },
  "homepage": "https://github.com/stevenjoezhang/bilibili-downloader",
  "dependencies": {
    "bootstrap": "^5.3.3",
    "ffmpeg-static": "^5.2.0",
    "filenamify": "^7.0.2",
    "fluent-ffmpeg": "^2.1.3",
    "jquery": "^4.0.0",
    "mime": "^4.1.0",
    "node-fetch": "^3.3.2",
    "progress-stream": "^2.0.0",
    "qrcode": "^1.5.3",
    "tough-cookie": "^6.0.1"
